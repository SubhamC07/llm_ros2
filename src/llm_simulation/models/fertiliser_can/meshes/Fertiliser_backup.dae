  <library_effects>
    <effect id="aruco_tag_3_effect">
      <profile_COMMON>
        <newparam sid="aruco_tag_3.jpg-surface">
          <surface type="2D">
            <init_from>aruco_tag_3.jpg</init_from>
          </surface>
        </newparam>
        <newparam sid="aruco_tag_3.jpg-sampler">
          <sampler2D>
            <source>aruco_tag_3.jpg-surface</source>
          </sampler2D>
        </newparam>
        <technique sid="common">
          <lambert>
            <diffuse>
              <texture texture="aruco_tag_3.jpg-sampler" texcoord="UVMap"/>
