<?xml version="1.0" encoding="utf-8"?>
<COLLADA xmlns="http://www.collada.org/2005/11/COLLADASchema" version="1.4.1">
  <asset>
    <contributor>
      <authoring_tool>Subham Chhotaray</authoring_tool>
    </contributor>
    <created>2026-03-16T00:00:00</created>
    <modified>2026-03-16T00:00:00</modified>
    <unit name="meter" meter="1"/>
    <up_axis>Z_UP</up_axis>
  </asset>

  <library_geometries>
    <geometry id="cuboid-mesh" name="cuboid-mesh">
      <mesh>
        <!-- 8 vertices (x,y,z) -->
        <source id="cuboid-positions">
          <float_array id="cuboid-positions-array" count="24">
-0.2 -0.025 -0.2  0.2 -0.025 -0.2  0.2 0.025 -0.2  -0.2 0.025 -0.2
-0.2 -0.025  0.2  0.2 -0.025  0.2  0.2 0.025  0.2  -0.2 0.025  0.2
          </float_array>
          <technique_common>
            <accessor source="#cuboid-positions-array" count="8" stride="3">
              <param name="X" type="float"/>
              <param name="Y" type="float"/>
              <param name="Z" type="float"/>
            </accessor>
          </technique_common>
        </source>

        <vertices id="cuboid-vertices">
          <input semantic="POSITION" source="#cuboid-positions"/>
        </vertices>

        <!-- 12 triangles (two per face) -->
        <triangles count="12">
          <input semantic="VERTEX" source="#cuboid-vertices" offset="0"/>
          <!-- triangle index list (using vertex indices 0..7) -->
          <p>
            0 1 2  0 2 3      <!-- bottom (z = -0.2) -->
            4 5 6  4 6 7      <!-- top (z =  0.2) -->
            3 2 6  3 6 7      <!-- front (y =  0.025) -->
            0 4 5  0 5 1      <!-- back  (y = -0.025) -->
            0 3 7  0 7 4      <!-- left  (x = -0.2) -->
            1 5 6  1 6 2      <!-- right (x =  0.2) -->
          </p>
        </triangles>

      </mesh>
    </geometry>
  </library_geometries>

  <library_visual_scenes>
    <visual_scene id="Scene">
      <node id="cuboid-node" name="cuboid-node">
        <instance_geometry url="#cuboid-mesh"/>
      </node>
    </visual_scene>
  </library_visual_scenes>

  <scene>
    <instance_visual_scene url="#Scene"/>
  </scene>
</COLLADA>
