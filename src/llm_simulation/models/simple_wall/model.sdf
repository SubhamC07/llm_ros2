<?xml version="1.0" ?>
<sdf version="1.7">
  <model name="simple_wall">

    <static>true</static>

    <link name="link">

      <pose>0 0 0 0 0 0</pose>

      <collision name="collision">
        <geometry>
          <box>
            <!-- 40cm x 5cm x 40cm -->
            <size>40.0 40.0 0.05</size>
            <!-- <size>0.4 0.05 0.4</size> -->
          </box>
        </geometry>
      </collision>

      <visual name="visual">
        <geometry>
          <box>
            <size>40.0 40.0 0.05</size>
            <!-- <size>0.4 0.05 0.4</size> -->
          </box>
        </geometry>

        <!-- <material>
          <ambient>0.8 0.8 0.8 1</ambient>
          <diffuse>0.8 0.8 0.8 1</diffuse>
        </material> -->
        <material>
          <ambient>0.05 0.05 0.05 1</ambient>
	        <diffuse>0.1 0.1 0.1 1</diffuse>
        </material>

      </visual>

    </link>

  </model>
</sdf>
