<?xml version="1.0"?>
<robot name="anvrit"  xmlns:xacro="http://www.ros.org/wiki/xacro" >
  <xacro:include filename="$(find llm_description)/urdf/materials.xacro"/>
  <xacro:property name="mesh_scale" value="1 1 1"/>
  

  <link name ="base_footprint"> </link>

    <joint name="footprint_joint" type="fixed">
         <origin xyz="0.0 0.0 0.05"
                rpy="0 0 0" />
        <parent link="base_footprint"/>
        <child link="base_link"/>        
    </joint>

  <!--Base link-->
  <link name="base_link">
    <inertial>
      <origin xyz="0.0 0.0 0.0"
              rpy="0 0 0"/>
      <mass value="0.1273483184846"/>
      <inertia 
        ixx="0.00123751350168177" 
        ixy="3.74427957165197e-07" 
        ixz="1.89270156971878e-05"
        iyy="0.00110888620697979" 
        iyz="2.06169390199287e-07" 
        izz="0.00221733682883006"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename ="file://$(find llm_description)/rosbot/base_link.STL" scale="${mesh_scale}"/>
      </geometry>
      <material name="">
        <color rgba="0.752941176470588 0.752941176470588 0.752941176470588 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename ="file://$(find llm_description)/rosbot/base_link.STL" scale="${mesh_scale}"/>
      </geometry>
    </collision>
  </link>

  <!--Lidar link-->
  <link name="laser">
    <inertial>
      <origin xyz="-0.000953640118147256 -0.000576727920655976 -0.0118094831256821"
              rpy="0 0 0"/>
      <mass value="0.0843723828446117"/>
      <inertia
        ixx="2.96770201798007e-05"
        ixy="8.63682564469207e-07"
        ixz="2.23496741128563e-07"
        iyy="2.92387310540492e-05"
        iyz="1.43437621269928e-07"
        izz="5.09273170751965e-05"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename ="file://$(find llm_description)/rosbot/lidar_link.STL" scale="${mesh_scale}"/>
      </geometry>
      <material name="">
        <color rgba="0.792156862745098 0.819607843137255 0.933333333333333 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename ="file://$(find llm_description)/rosbot/lidar_link.STL" scale="${mesh_scale}"/>
      </geometry>
    </collision>
  </link>

  <joint name="lidar_joint" type="fixed">
    <origin xyz="0.015996 0 0.191" rpy="0 0 -2.3496"/>
    <parent link="base_link"/>
    <child  link="laser"/>
  </joint>

  <!--Wheel 1 link-->
  <link name="wheel_1_link">
    <inertial>
      <origin xyz="3.14945708401737e-11 3.75410189046299e-11 0.0103816204197174"
              rpy="0 0 0"/>
      <mass value="0.5351746985822268"/>
      <inertia
        ixx="1.52375714421183e-05"
        ixy="-6.1555264940674e-15"
        ixz="-5.26141924875821e-16"
        iyy="1.52365776606531e-05"
        iyz="-4.25198086664995e-14"
        izz="2.57857822002638e-05"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename ="file://$(find llm_description)/rosbot/wheel_1_link.STL" scale="${mesh_scale}"/>
      </geometry>
      <material name="">
        <color rgba="0.752941176470588 0.752941176470588 0.752941176470588 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename ="file://$(find llm_description)/rosbot/wheel_1_link.STL" scale="${mesh_scale}"/>
      </geometry>
    </collision>
  </link>

  <!--Wheel 1 joint-->
  <joint name="wheel_1_joint" type="continuous">
      <origin xyz="0 -0.10033 -0.034" rpy="1.5708 -0.91139 0"/>
      <parent link="base_link"/>
      <child  link="wheel_1_link"/>
      <axis  xyz="0 0 1"/>
  </joint>

  <!--Wheel 2 link-->
  <link name="wheel_2_link">
    <inertial>
      <origin xyz="-3.14945708401737e-11 -3.75409946185012e-11 0.0103816204197174"
              rpy="0 0 0"/>
      <mass value="0.5351746985822268"/>
      <inertia
        ixx="1.52375714421071e-05"
        ixy="-6.15554724637461e-15"
        ixz="5.24933422293082e-16"
        iyy="1.52365776606417e-05"
        iyz="4.2520611227863e-14"
        izz="2.57857822002639e-05"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename ="file://$(find llm_description)/rosbot/wheel_2_link.STL" scale="${mesh_scale}"/>
      </geometry>
      <material name="">
        <color rgba="0.752941176470588 0.752941176470588 0.752941176470588 1"/>
      </material>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename ="file://$(find llm_description)/rosbot/wheel_2_link.STL" scale="${mesh_scale}"/>
      </geometry>
    </collision>
  </link>

  <!--Wheel 2 joint-->
  <joint name="wheel_2_joint" type="continuous">
      <origin xyz="0 0.10033 -0.034" rpy="-1.5708 -0.98056 0"/>
      <parent link="base_link"/>
      <child  link="wheel_2_link"/>
      <axis  xyz="0 0 1"/>
  </joint>

   <gazebo reference="laser">
    <sensor name="laser" type="gpu_lidar">
      <always_on>true</always_on>
      <visualize>false</visualize>
      <topic>scan</topic>
      <pose>0 0 0 0 0 0</pose>
      <update_rate>10</update_rate>
      <gz_frame_id>laser</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1.0</resolution>
            <min_angle>-3.14</min_angle>
            <max_angle>3.14</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>0.01</resolution>
            <min_angle>0</min_angle>
            <max_angle>0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.8</min>
          <max>8.0</max>
          <resolution>0.02</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </lidar>
    </sensor>
  </gazebo>

   <gazebo>
    <plugin filename="ignition-gazebo-diff-drive-system" name="ignition::gazebo::systems::DiffDrive">
      <left_joint>wheel_2_joint</left_joint>
      <right_joint>wheel_1_joint</right_joint>
      <wheel_separation>0.20066</wheel_separation>
      <wheel_diameter>0.100</wheel_diameter>
      <max_acceleration>10.0</max_acceleration>
      <max_linear_velocity>5.0</max_linear_velocity>
      <min_linear_velocity>-5.0</min_linear_velocity>
      <max_angular_velocity>2.0</max_angular_velocity>
      <min_angular_velocity>-2.0</min_angular_velocity>
      <topic>cmd_vel</topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_footprint</child_frame_id>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="ignition-gazebo-odometry-publisher-system" name="ignition::gazebo::systems::OdometryPublisher">
      <odom_topic>odom</odom_topic>
      <odom_frame>odom</odom_frame>
      <tf_topic>tf</tf_topic>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>

  <gazebo>
    <plugin filename="ignition-gazebo-joint-state-publisher-system" name="ignition::gazebo::systems::JointStatePublisher">
      <topic>joint_states</topic>
      <joint_name>wheel_1_joint</joint_name>
      <joint_name>wheel_2_joint</joint_name>
    </plugin>
  </gazebo>



</robot>